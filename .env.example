# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Azure OpenAI deployment names
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT=gpt-4o-mini-transcribe
AZURE_OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# Twilio (outbound calling)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Public URL Twilio can reach (e.g. your ngrok https URL, no trailing slash)
PUBLIC_BASE_URL=https://your-id.ngrok.io

# App
AUTH_SECRET=replace_with_a_long_random_secret

# Database (Postgres in Docker — host port 5434)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=call_pilot
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5434/call_pilot
